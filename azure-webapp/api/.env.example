# Copy to .env for local development. Never commit .env.
# Azure variant — see AZURE.md for the GCP->Azure mapping.
NODE_ENV=development
PORT=8080

# ── Azure identity (local dev) ─────────────────────────────────────────────
# In the cloud, the Container App's user-assigned managed identity is used via
# DefaultAzureCredential (AZURE_CLIENT_ID is injected by deploy-api.sh). Locally,
# `az login` provides the credential — leave AZURE_CLIENT_ID unset in dev.
# AZURE_CLIENT_ID=

# ── Cosmos DB (was Firestore) ──────────────────────────────────────────────
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_DATABASE=eventphotos

# ── Blob Storage (was Cloud Storage) ───────────────────────────────────────
STORAGE_ACCOUNT=your-storage-account
PHOTOS_CONTAINER=photos
DERIVATIVES_CONTAINER=derivatives
STAGING_CONTAINER=staging

# Allow the Vite dev server to call this api directly in dev.
CORS_ORIGINS=http://localhost:5173

# Optional: set to silence the health-check log spam locally
LOG_LEVEL=debug

# ── Abuse protection / rate limits (dev plan §5B) ──────────────────────────
# Per-user fixed-window counters. A limit of 0 disables that bucket.
FINDME_SEARCH_LIMIT=20
FINDME_SEARCH_WINDOW_SEC=60
DOWNLOAD_LIMIT_PER_DAY=50
ORIGINAL_FETCH_LIMIT=500
VOLUNTEER_UPLOAD_LIMIT=2000
VOLUNTEER_UPLOAD_WINDOW_SEC=3600

# ── Secrets (prod: Key Vault refs injected by deploy-api.sh) ───────────────
# Locally you can set these directly; in prod they come from Key Vault.
# SYNC_TRIGGER_TOKEN=
# CONSENT_POLICY_VERSION=v1
# RECAPTCHA_KEY=

# ── reCAPTCHA Enterprise (optional) ────────────────────────────────────────
# RECAPTCHA_PROJECT_ID=
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_API_KEY=

# ── matcher (internal Container App URL; auto-set in prod) ──────────────────
# MATCHER_URL=https://matcher.internal.<env>.azurecontainerapps.io
