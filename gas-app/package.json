{
  "name": "xiangsheidong-file-system",
  "version": "1.0.0",
  "private": true,
  "description": "湘舍动公益文件系统 — Google Apps Script v1",
  "scripts": {
    "login": "clasp login",
    "push": "clasp push",
    "push:watch": "clasp push --watch",
    "pull": "clasp pull",
    "deploy": "clasp deploy",
    "open": "clasp open",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=html",
    "typecheck": "tsc --noEmit --pretty",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
