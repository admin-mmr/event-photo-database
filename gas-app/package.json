{
  "name": "xiangsheidong-file-system",
  "version": "1.0.0",
  "private": true,
  "description": "湘舍动公益文件系统 — Google Apps Script v1",
  "scripts": {
    "login": "clasp login",
    "build": "node esbuild.mjs",
    "build:watch": "node esbuild.mjs --watch",
    "stamp": "node esbuild.mjs --stamp-only",
    "push": "npm run build && npm run stamp && clasp push",
    "push:watch": "npm run build:watch",
    "pull": "clasp pull",
    "deploy": "clasp deploy",
    "open": "clasp open",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=html",
    "typecheck": "tsc --noEmit --pretty",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^1.0.83",
    "@types/jest": "^29.5.12",
    "esbuild": "^0.28.0",
    "esbuild-gas-plugin": "^0.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
