# Copy to .env for local development. Never commit .env.
NODE_ENV=development
PORT=8080

# GCP project IDs (only needed locally; auto-detected on Cloud Run)
GCP_PROJECT_ID=your-project-id
FIREBASE_PROJECT_ID=your-project-id

# Allow the Vite dev server to call this api directly in dev.
CORS_ORIGINS=http://localhost:5173

# Optional: set to silence the health-check log spam locally
LOG_LEVEL=debug

# ── Abuse protection / rate limits (dev plan §5B) ──────────────────────────
# Per-user Firestore fixed-window counters (middleware/rateLimit.ts). A limit
# of 0 disables that bucket. These mirror the schema defaults in config.ts;
# deploy-api.sh sets them explicitly in prod so they're never left to chance.
# Find Me searches per window:
FINDME_SEARCH_LIMIT=20
FINDME_SEARCH_WINDOW_SEC=60
# Bulk ZIP downloads per day (one ZIP = one, regardless of photo count):
DOWNLOAD_LIMIT_PER_DAY=50
# Single-photo "Save individually"/"Save to Photos" fetches per day. Its OWN
# bucket: one save fans out into N requests, so keep this generous.
ORIGINAL_FETCH_LIMIT=500
# Volunteer upload /session calls per window, keyed on the LINK TOKEN (one call
# per file). Guards a leaked link from filling the staging bucket; 0 disables.
VOLUNTEER_UPLOAD_LIMIT=2000
VOLUNTEER_UPLOAD_WINDOW_SEC=3600

# ── reCAPTCHA Enterprise (optional; all three enable the gate) ─────────────
# Server-side verification for /session (and Find Me search). Leave blank for
# dev/demo — the gate no-ops. The web client also needs VITE_RECAPTCHA_SITE_KEY
# at build time to actually mint a token.
# RECAPTCHA_PROJECT_ID=
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_API_KEY=
