# Copy to .env for local development. Never commit .env.
NODE_ENV=development
PORT=8080

# GCP project IDs (only needed locally; auto-detected on Cloud Run)
GCP_PROJECT_ID=your-project-id
FIREBASE_PROJECT_ID=your-project-id

# Allow the Vite dev server to call this api directly in dev.
CORS_ORIGINS=http://localhost:5173

# Optional: set to silence the health-check log spam locally
LOG_LEVEL=debug
