{
  "name": "cloud-webapp",
  "version": "0.1.0",
  "private": true,
  "description": "Event Photo Database — Cloud Run + Firebase Hosting + Firestore implementation",
  "workspaces": [
    "shared",
    "api",
    "web"
  ],
  "engines": {
    "node": ">=20.0.0 <21",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "check": "npm run typecheck --workspaces --if-present && npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "concurrently": "^9.0.1"
  }
}
