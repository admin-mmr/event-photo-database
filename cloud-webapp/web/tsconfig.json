{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["vite/client", "vitest/globals"],
    "noEmit": true
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../shared" }, { "path": "./tsconfig.node.json" }]
}
